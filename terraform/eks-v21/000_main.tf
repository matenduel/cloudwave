#########################################################################################################
## AWS Provider와 공통 태그
#########################################################################################################

# 모든 자원에 공통으로 붙는 태그입니다. 콘솔에서 "누가 무엇 때문에 만든 자원인지"를 태그로 찾고,
# 비용 화면에서도 태그 단위로 걸러 볼 수 있습니다. 자원이 수십 개씩 생기는 EKS에서는
# 태그가 곧 정리(청소)의 근거가 됩니다.
locals {
  tags = {
    project     = "cloudwave-eks" # 어느 프로젝트(실습)의 자원인지
    owner       = var.owner       # 만든 사람. 공용 계정에서 자기 자원을 찾는 기준
    environment = "lab"           # 실습 환경 표시. prod가 아니므로 지워도 되는 자원임을 알림
    managed_by  = "terraform"     # 콘솔에서 손대지 말고 코드로 고치라는 신호
  }
}

provider "aws" {
  region = var.region

  # default_tags: 이 provider로 만드는 모든 자원에 위 태그를 자동으로 붙입니다.
  # 자원마다 tags를 반복해 적지 않아도 되고, 태그를 빠뜨린 자원이 생기지 않습니다.
  # (EKS가 간접적으로 만드는 EC2 인스턴스 등 일부 자원에는 전파되지 않습니다.)
  default_tags {
    tags = local.tags
  }
}
